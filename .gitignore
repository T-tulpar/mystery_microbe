# .gitignore for bioinformatics projects

# Raw and processed data (too large for Git)
data/raw/
data/processed/
*.fastq
*.fastq.gz
*.fasta
*.fa
*.bam
*.bai
*.sam
*.vcf
*.vcf.gz
*.bed

# Results (regenerated by pipeline)
results/

# Reference genomes
*.fa.fai
*.dict
*.bt2
*.amb
*.ann
*.bwt
*.pac
*.sa

# R artifacts
.Rhistory
.RData
.Rproj.user/

# Python artifacts
__pycache__/
*.pyc
.ipynb_checkpoints/

# Snakemake
.snakemake/

# OS files
.DS_Store
Thumbs.db
